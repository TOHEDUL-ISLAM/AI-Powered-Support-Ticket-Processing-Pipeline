{
  "name": "ai-ticket-pipeline",
  "version": "0.1.0",
  "description": "AI-powered support ticket processing pipeline — 2-phase triage and resolution draft via async SQS workers.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --pool=forks --poolOptions.forks.singleFork=true --fileParallelism=false",
    "test:e2e": "vitest run tests/e2e --pool=forks --poolOptions.forks.singleFork=true --fileParallelism=false",
    "test:coverage": "vitest run --coverage --pool=forks --poolOptions.forks.singleFork=true --fileParallelism=false",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "migrate": "node-pg-migrate --migrations-dir src/migrations --envpath .env up",
    "migrate:down": "node-pg-migrate --migrations-dir src/migrations --envpath .env down",
    "migrate:reset": "npm run migrate:down && npm run migrate:down && npm run migrate:down && npm run migrate",
    "setup": "bash scripts/setup.sh",
    "postgres:start": "docker compose -f ../docker-compose.yml up -d postgres",
    "postgres:stop": "docker compose -f ../docker-compose.yml stop postgres",
    "localstack:start": "cd .. && uv run localstack start",
    "localstack:stop": "cd .. && uv run localstack stop",
    "socket:client": "node scripts/socket-client.js"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1037.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "portkey-ai": "^1.10.4",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "node-pg-migrate": "^7.9.1",
    "nodemon": "^3.1.14",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
